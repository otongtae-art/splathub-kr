{
  "name": "splathub",
  "version": "0.1.0",
  "private": true,
  "description": "SplatHub-KR: 웹캠/카메라 직접 캡처 → 3D Gaussian Splat 변환 엔진 + 공유 커뮤니티",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @splathub/web dev",
    "build": "pnpm --filter @splathub/web build",
    "start": "pnpm --filter @splathub/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf node_modules .next dist"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
