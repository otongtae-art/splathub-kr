# ────────────────────────────────────────────────────────────
# SplatHub-KR / apps/web — environment variables
# Copy to `.env.local` and fill in. Never commit real keys.
# ────────────────────────────────────────────────────────────

# Supabase (DB + Auth + Realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=splathub-dev
R2_PUBLIC_BASE=https://pub-<hash>.r2.dev

# Upstash Redis (queue + rate-limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GPU workers
HF_SPACE_URL=https://OWNER-splat-worker-free.hf.space
HF_API_TOKEN=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
REPLICATE_API_TOKEN=

# Worker callback HMAC
JOB_CALLBACK_SECRET=change-me-to-random-32-byte-hex

# Observability
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
